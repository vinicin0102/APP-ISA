# URL e Auth Key do seu banco de dados Supabase (Pegue isso em Project Settings -> API)
VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Para as notificações Push (PWA) funcionarem de verdade
# 1. Entre no site: https://vapidkeys.com/ e gere chaves novas
# 2. Cole a "Public Key" aqui abaixo. 
# 3. A "Private Key" você vai usar EXCLUSIVAMENTE no servidor/backend/crons (ex: edge functions). Nunca exponha no frontend!
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_HERE
